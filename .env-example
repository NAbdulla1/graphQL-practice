# Server Configuration
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=file:./dev.db

# Redis
REDIS_URL=redis://localhost:6379

# Frontend URL, when deployed in a real server the port should be the public facing port
FRONTEND_URL=http://localhost:5173

# Google OAuth 2.0
# Get these from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# when deployed in a real server the port should be the public facing port
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# Session Secret
SESSION_SECRET=a-long-random-string-for-session-security

